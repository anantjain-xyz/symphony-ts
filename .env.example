# Local Supabase (started via `supabase start`)
# Worker uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# Dashboard uses the NEXT_PUBLIC_* versions (inlined into the client bundle).
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=         # from `supabase status` -> Secret
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # from `supabase status` -> Publishable

# Linear API
LINEAR_API_KEY=

# Worker
WORKFLOW_PATH=./WORKFLOW.md
LOG_LEVEL=info

# Target Linear team / repo. Read by WORKFLOW.md via ${VAR} interpolation,
# so retargeting at a new team or repo is an .env.local edit (no WORKFLOW.md change).
REPO_URL=                          # git URL cloned by after_create hook
SYMPHONY_LINEAR_WORKSPACE=         # workspace slug — linear.app/<slug>/... ; enables dashboard "linear ↗" links
SYMPHONY_TRACKER_PREFIX=           # issue-identifier prefix (e.g. PB-); leave blank if the API key sees only one team
SYMPHONY_TRACKER_PROJECT_ID=       # Linear project UUID to restrict the worker to; leave blank to scope by team only (or not at all)
SYMPHONY_INSTALL_CMD=              # install command for after_create (e.g. "npm ci", "pnpm install --frozen-lockfile"); blank → npm ci
