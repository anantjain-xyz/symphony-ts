# Local Supabase (started via `supabase start`)
# Worker uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# Dashboard uses the NEXT_PUBLIC_* versions (inlined into the client bundle).
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=         # from `supabase status` -> Secret
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # from `supabase status` -> Publishable

# Linear API
LINEAR_API_KEY=

# Worker
WORKFLOW_PATH=./WORKFLOW.md
LOG_LEVEL=info
REPO_URL=                          # git URL cloned by after_create hook

# Dashboard
ALLOWED_OPERATOR_EMAILS=           # comma-separated
