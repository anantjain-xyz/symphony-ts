{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "apps/dashboard/next-env.d.ts",
      "node_modules",
      ".next",
      "packages/shared/src/db-types.ts",
      "supabase/.branches",
      "supabase/.temp"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
