# ----- Without Docker -----------------------------------------------------
# `supabase start` brings up the local stack on 54421 and prints keys; copy
# the values it gives you here (and `cp .env.example .env.local`).
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=         # from `supabase status` -> Secret
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # from `supabase status` -> Publishable

# Linear API
LINEAR_API_KEY=

# Worker
WORKFLOW_PATH=./WORKFLOW.md
LOG_LEVEL=info
REPO_URL=                          # git URL cloned by after_create hook

# ----- Docker (`docker compose up`) ---------------------------------------
# The compose stack ships well-known dev JWT secrets; only LINEAR_API_KEY is
# read from your environment (the worker won't poll without it).
#   LINEAR_API_KEY=...
# Override default ports if 54421/54422/3000 collide with something local:
#   SUPABASE_PORT=64421
#   POSTGRES_PORT=64422
#   DASHBOARD_PORT=63000
#   PUBLIC_SUPABASE_URL=http://localhost:64421   # match SUPABASE_PORT
