{
  "name": "symphony-ts",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript port of Symphony — a long-running daemon and dashboard that polls Linear, provisions per-issue workspaces, and runs Claude Code / Codex coding agents with retries and live observability, backed by Supabase.",
  "keywords": [
    "symphony",
    "linear",
    "supabase",
    "claude-code",
    "codex",
    "coding-agent",
    "monorepo",
    "typescript"
  ],
  "homepage": "https://github.com/anantjain-xyz/symphony-ts#readme",
  "bugs": {
    "url": "https://github.com/anantjain-xyz/symphony-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anantjain-xyz/symphony-ts.git"
  },
  "license": "MIT",
  "author": "Anant Jain",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "format": "biome format --write",
    "format:check": "biome format",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "biome lint",
    "typecheck": "pnpm -r typecheck",
    "db:types": "supabase gen types typescript --local > packages/shared/src/db-types.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
