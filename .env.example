# Local Supabase (started via `supabase start`)
# Worker and dashboard both call Supabase server-side with the service-role key.
# The dashboard no longer ships a key to the browser, so there is no
# NEXT_PUBLIC_SUPABASE_* anymore.
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=         # from `supabase status` -> Secret

# Linear API
LINEAR_API_KEY=

# Worker
WORKFLOW_PATH=./WORKFLOW.md
LOG_LEVEL=info
REPO_URL=                          # git URL cloned by after_create hook

# Dashboard auth (operator login)
# Comma-separated list of emails allowed to sign in.
ALLOWED_OPERATOR_EMAILS=you@example.com
# HMAC secret for session + magic-link cookies. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
DASHBOARD_SESSION_SECRET=
