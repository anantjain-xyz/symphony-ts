{
  "name": "symphony-ts",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript port of Symphony — a long-running daemon and dashboard that polls Linear, provisions per-issue workspaces, and runs Claude Code / Codex coding agents with retries and live observability, backed by Postgres.",
  "keywords": [
    "symphony",
    "linear",
    "postgres",
    "claude-code",
    "codex",
    "coding-agent",
    "monorepo",
    "typescript"
  ],
  "homepage": "https://github.com/anantjain-xyz/symphony-ts#readme",
  "bugs": {
    "url": "https://github.com/anantjain-xyz/symphony-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anantjain-xyz/symphony-ts.git"
  },
  "license": "MIT",
  "author": "Anant Jain",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "format": "biome format --write",
    "format:check": "biome format",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "biome lint",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose -f db/docker-compose.yml up -d",
    "db:down": "docker compose -f db/docker-compose.yml down",
    "db:migrate": "tsx --env-file-if-exists=.env.local db/migrate.ts",
    "db:reset": "docker compose -f db/docker-compose.yml down -v && pnpm db:up && until docker exec symphony-postgres pg_isready -U symphony -d symphony >/dev/null 2>&1; do sleep 1; done && pnpm db:migrate",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^25.7.0",
    "postgres": "^3.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
