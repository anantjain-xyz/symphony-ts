{
  "name": "@symphony/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Symphony worker daemon — polls Linear, dispatches Claude Code / Codex sessions per issue, streams events to Supabase, and retries with backoff.",
  "keywords": [
    "symphony",
    "worker",
    "daemon",
    "linear",
    "supabase",
    "claude-code",
    "codex"
  ],
  "homepage": "https://github.com/anantjain-xyz/symphony-ts/tree/main/apps/worker#readme",
  "bugs": {
    "url": "https://github.com/anantjain-xyz/symphony-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anantjain-xyz/symphony-ts.git",
    "directory": "apps/worker"
  },
  "license": "Apache-2.0",
  "author": "Anant Jain",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "attach": "tsx src/cli/attach.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.47.10",
    "@symphony/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "execa": "^9.5.2",
    "graphql-request": "^7.1.2",
    "gray-matter": "^4.0.3",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
